#
# Local environment configuration for Stock-Pulse
#
# Notes:
# - Keep this file local; do not commit secrets.
# - Paths are optional; code defaults to repo-relative locations.
#

# Environment name: dev | test | prod
#ENV=dev

# Base directory override (optional). Leave blank to auto-detect.
# BASE_DIR=

# Data directories (optional overrides)
#INCOMING_DIR=
#ARCHIVE_DIR=
#REJECTED_DIR=

# Warehouse / DB (fill in when you wire DB loading)
# DB_URL=

DB_SERVER=localhost\SQLEXPRESS
DB_NAME=StockPulse

# IMPORTANT (Windows): URL-encode spaces for SQLAlchemy/pyodbc URLs.
# Recommended: encode in .env
DB_DRIVER=ODBC+Driver+17+for+SQL+Server

# Auth mode (pick ONE)
# Windows Authentication (Trusted Connection)
DB_TRUSTED_CONNECTION=yes

# SQL Login (comment out DB_TRUSTED_CONNECTION if you use these)
# DB_USERNAME=your_user
# DB_PASSWORD=your_password